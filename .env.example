# ============================================================
# CONSTRUCTION ESTIMATOR — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git
# ============================================================

# ------------------------------------------------------------
# AGENTROUTER — Single gateway for ALL LLM calls
# Claude Opus 4.6, DeepSeek V4-Pro, Claude Haiku via one key
# Get your key at: https://agentrouter.org → Dashboard
# ------------------------------------------------------------
AGENTROUTER_API_KEY=your_agentrouter_key_here
AGENTROUTER_BASE_URL=https://agentrouter.org/v1

# ------------------------------------------------------------
# OPENAI — Used ONLY for text-embedding-3-small (RAG)
# NOT used for chat completions (those go through AgentRouter)
# Get your key at: https://platform.openai.com
# Recommended: load $10 minimum
# ------------------------------------------------------------
OPENAI_API_KEY=your_openai_key_here

# ------------------------------------------------------------
# TAVILY — Web search for real-time pricing research
# Free tier: 1,000 searches/month (no credit card needed)
# Get your key at: https://tavily.com
# ------------------------------------------------------------
TAVILY_API_KEY=your_tavily_key_here

# ------------------------------------------------------------
# APP CONFIGURATION
# ------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ------------------------------------------------------------
# FILE PATHS (defaults — change only if needed)
# ------------------------------------------------------------
OUTPUTS_DIR=outputs
KNOWLEDGE_BASE_DIR=knowledge_base
SAMPLES_DIR=samples
CHROMA_DB_PATH=chroma_db

# ------------------------------------------------------------
# JOB CONFIGURATION
# ------------------------------------------------------------
MAX_CONCURRENT_JOBS=1
JOB_TIMEOUT_SECONDS=10800

# ------------------------------------------------------------
# RAG CONFIGURATION
# ------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_COLLECTION_NAME=construction_kb
RAG_TOP_K=10

# ------------------------------------------------------------
# PRICING CONFIGURATION (override per project if needed)
# ------------------------------------------------------------
DEFAULT_CONTINGENCY_PCT=10
DEFAULT_OVERHEAD_PCT=12
DEFAULT_MARGIN_PCT=15
DEFAULT_CURRENCY=USD
DEFAULT_REGION=GCC
